# Token del bot de Telegram (obtenerlo con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ============================== Proveedor de IA ==============================
# AI_PROVIDER: "anthropic" (Claude) o "openai" (cualquier API compatible con
# OpenAI: OpenAI, Gemini, Groq, DeepSeek, Mistral, OpenRouter, Ollama...).
AI_PROVIDER=anthropic

# Modelo a usar. Por defecto: claude-opus-4-8 (anthropic) o gpt-4o (openai).
# El modelo debe soportar VISIÓN para poder leer fotos de facturas.
#AI_MODEL=claude-opus-4-8

# API key del proveedor. También puedes usar ANTHROPIC_API_KEY u
# OPENAI_API_KEY según el proveedor.
AI_API_KEY=sk-...

# Endpoint personalizado (solo para AI_PROVIDER=openai). Ejemplos:
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai/
#   Groq:       https://api.groq.com/openai/v1
#   Mistral:    https://api.mistral.ai/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1
#AI_BASE_URL=

# ============================== Interfaz web ================================
# Clave secreta para firmar las cookies de sesión (usa una cadena larga y
# aleatoria). Si no se define, las sesiones se cierran al reiniciar la web.
#WEB_SECRET_KEY=cambia-esto-por-una-cadena-aleatoria-larga

# URL pública del panel (la que el bot muestra con /web)
#WEB_URL=http://localhost:8642

# Host y puerto donde escucha el servidor web
#WEB_HOST=0.0.0.0
#WEB_PORT=8642

# Opcional: ruta de la base de datos SQLite
#AUDITORIA_DB_PATH=auditoria.db
